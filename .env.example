# ─────────────────────────────────────────────
# This file documents all environment variables.
# Docker Compose reads these from the docker-compose.yml directly.
# Copy this to .env if you want to override values locally.
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Keycloak Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Backend
PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://sso_app_user:sso_app_pass@postgres:5432/sso_app
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/sso-poc/protocol/openid-connect/certs
KEYCLOAK_ISSUER=http://localhost:8080/realms/sso-poc
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Google OAuth (optional — to enable Google login)
# 1. Create a project at https://console.cloud.google.com
# 2. Enable Google OAuth 2.0 API
# 3. Create credentials (Web application type)
# 4. Add authorized redirect URI:
#    http://localhost:8080/realms/sso-poc/broker/google/endpoint
# 5. Set these values and set enabled=true in keycloak/realm-export.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
